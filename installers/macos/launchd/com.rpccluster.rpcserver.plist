<?xml version="1.0" encoding="utf-8"?>
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.rpccluster.rpcserver</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/rpc-server</string>
        <string>-H</string>
        <string>0.0.0.0</string>
        <string>-p</string>
        <string>50052</string>
        <string>-m</string>
        <string>0</string>
    </array>
    
    <key>RunAtLoad</key>
    <true/>
    
    <key>KeepAlive</key>
    <true/>
    
    <key>StandardOutPath</key>
    <string>/var/log/rpc-server.log</string>
    
    <key>StandardErrorPath</key>
    <string>/var/log/rpc-server.log</string>
    
    <key>WorkingDirectory</key>
    <string>/var/cache/llama-rpc</string>
    
    <!-- Restart on crash with a delay -->
    <key>ThrottleInterval</key>
    <integer>5</integer>
    
    <!-- Environment variables -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
